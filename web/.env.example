# Drizzle / SQLite
DATABASE_URL=file:./data/llmproxy-share.db

# Optional API auth for POST /api/shares
SHARE_UPLOAD_API_KEY=

# Object storage (S3 compatible). If OBJECT_STORAGE_BUCKET is empty, local file fallback is used.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Local fallback storage directory
OBJECT_STORAGE_LOCAL_DIR=.storage
